<?php
/**
 * @file
 * Custom hooks for the Cove project.
 */

declare(strict_types=1);

use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;
use Drupal\views\Plugin\views\query\QueryPluginBase;
use Drupal\taxonomy\TermInterface;
use Drupal\views\ResultRow;
use Drupal\views\Plugin\views\query\Sql;
use Drupal\views\ViewExecutable;

/**
 * @file
 * Custom hooks for COVE.
 */

/**
 * Implements hook_views_query_alter().
 *
 * Pin parent content types (Timeline, Map, Gallery Exhibit, Blog) above their
 * children in cove_og_content.
 */
function cove_custom_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  if ($view->id() !== 'cove_og_content' || !$query instanceof Sql) {
    return;
  }

  // NULL table makes Views compile this as a SQL expression.
  $query->addField(NULL, "CASE WHEN node_field_data.type IN ('chronology', 'map', 'galler_exhibit', 'blog') THEN 0 ELSE 1 END", 'cove_pin_shared');
  $query->addOrderBy(NULL, NULL, 'ASC', 'cove_pin_shared');

  // Prepend so this sort beats the existing 'created' DESC.
  $last = array_pop($query->orderby);
  array_unshift($query->orderby, $last);
}

/**
 * RGB anchors for the leaflet-color-markers palette PNGs (snapped at runtime).
 *
 * If you rename a key here, also update the matching `.cove-color-{key}` rule
 * in cove_editions_subtheme/css/map-pin-sequence.css.
 */
const COVE_CUSTOM_PIN_PALETTE = [
  'red' => [255, 0, 0],
  'blue' => [42, 129, 203],
  'green' => [42, 173, 39],
  'orange' => [203, 132, 39],
  'yellow' => [202, 196, 40],
  'violet' => [156, 43, 203],
  'grey' => [123, 123, 123],
  'black' => [61, 61, 61],
  'gold' => [201, 162, 43],
];

/**
 * Implements hook_leaflet_views_feature_alter().
 */
function cove_custom_leaflet_views_feature_alter(array &$feature, ResultRow $row, $rowPlugin): void {
  $node = $row->_entity ?? NULL;
  if (!$node instanceof NodeInterface
    || $node->bundle() !== 'place'
    || !$node->hasField('field_category')
    || $node->get('field_category')->isEmpty()) {
    return;
  }

  $term = $node->get('field_category')->entity;
  if (!$term instanceof TermInterface
    || !$term->hasField('field_color')
    || $term->get('field_color')->isEmpty()) {
    return;
  }

  $hex = ltrim((string) $term->get('field_color')->first()->get('color')->getValue(), '#');
  if (!preg_match('/^[0-9A-Fa-f]{6}$/', $hex)) {
    return;
  }

  $palette_color = _cove_custom_closest_palette_color($hex);
  $base = '/modules/custom/cove_custom/images';
  $feature['icon']['iconUrl'] = $base . '/marker-icon-' . $palette_color . '.png';
  $feature['icon']['shadowUrl'] = $base . '/marker-shadow.png';
  $feature['icon']['iconSize'] = ['x' => '25', 'y' => '41'];
  $feature['icon']['iconAnchor'] = ['x' => '12', 'y' => '41'];
  $feature['icon']['shadowSize'] = ['x' => '41', 'y' => '41'];
  $feature['icon']['shadowAnchor'] = ['x' => '12', 'y' => '41'];
  $feature['icon']['popupAnchor'] = ['x' => '1', 'y' => '-34'];

  // Tag the tooltip className so CSS can match the badge color to the pin.
  if (!empty($feature['tooltip']['options'])) {
    $tooltip_options = json_decode($feature['tooltip']['options'], TRUE);
    if (is_array($tooltip_options)) {
      $existing = $tooltip_options['className'] ?? '';
      $tooltip_options['className'] = trim($existing . ' cove-color-' . $palette_color);
      $feature['tooltip']['options'] = json_encode($tooltip_options);
    }
  }
}

/**
 * Implements hook_ENTITY_TYPE_update() for taxonomy_term.
 *
 * Refreshes the timeline / map caches so a term color change picks up
 * immediately.
 */
function cove_custom_taxonomy_term_update(TermInterface $term): void {
  $invalidator = \Drupal::service('cache_tags.invalidator');
  if ($term->bundle() === 'place_categories') {
    $invalidator->invalidateTags(['node_list:place', 'node_list:map']);
  }
  elseif ($term->bundle() === 'timeline_categories') {
    $invalidator->invalidateTags(['node_list:chronology_entry', 'node_list:chronology']);
  }
}

/**
 * Implements hook_inline_entity_form_entity_form_alter().
 *
 * Hides field_featured_in_exhibit when creating a gallery_image from an
 * exhibit context, CER fills it on the exhibit's own save.
 */
function cove_custom_inline_entity_form_entity_form_alter(array &$entity_form, FormStateInterface $form_state): void {
  if (($entity_form['#entity_type'] ?? '') !== 'node'
    || ($entity_form['#bundle'] ?? '') !== 'gallery_image'
    || ($entity_form['#op'] ?? '') !== 'add') {
    return;
  }

  if (_cove_custom_resolve_exhibit_from_request() === NULL) {
    return;
  }

  if (isset($entity_form['field_featured_in_exhibit'])) {
    $entity_form['field_featured_in_exhibit']['#access'] = FALSE;
  }
}

/**
 * Resolves the parent exhibit nid from routeMatch, then from entity_browser's
 * `original_path` query param (set on the modal iframe).
 */
function _cove_custom_resolve_exhibit_from_request(): ?int {
  $exhibit = \Drupal::routeMatch()->getParameter('node');
  if ($exhibit instanceof NodeInterface && $exhibit->bundle() === 'galler_exhibit' && $exhibit->access('view')) {
    return (int) $exhibit->id();
  }

  $original_path = \Drupal::request()->query->get('original_path');
  if (!is_string($original_path) || $original_path === '') {
    return NULL;
  }

  if (!preg_match('#^/node/(\d+)(?:/edit)?$#', $original_path, $matches)) {
    return NULL;
  }

  $node = \Drupal::entityTypeManager()->getStorage('node')->load((int) $matches[1]);
  if (!$node instanceof NodeInterface || $node->bundle() !== 'galler_exhibit' || !$node->access('view')) {
    return NULL;
  }

  return (int) $node->id();
}

/**
 * Returns the palette key closest (Euclidean RGB distance) to the given hex.
 */
function _cove_custom_closest_palette_color(string $hex): string {
  $r = hexdec(substr($hex, 0, 2));
  $g = hexdec(substr($hex, 2, 2));
  $b = hexdec(substr($hex, 4, 2));

  $best = 'blue';
  $best_distance = PHP_INT_MAX;
  foreach (COVE_CUSTOM_PIN_PALETTE as $name => [$pr, $pg, $pb]) {
    $distance = ($r - $pr) ** 2 + ($g - $pg) ** 2 + ($b - $pb) ** 2;
    if ($distance < $best_distance) {
      $best_distance = $distance;
      $best = $name;
    }
  }
  return $best;
}
