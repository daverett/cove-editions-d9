<?php

/**
 * @file
 * Per-course categories for COVE timelines, maps and galleries.
 */

declare(strict_types=1);

use Drupal\Core\Entity\EntityFormInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\cove_categories\Entity\CoveCategoryInterface;
use Drupal\node\NodeInterface;
use Drupal\views\ResultRow;

/**
 * RGB anchors for the leaflet-color-markers palette PNGs (snapped at runtime).
 *
 * If you rename a key here, also update the matching `.cove-color-{key}` rule
 * in cove_editions_subtheme/css/map-pin-sequence.css.
 */
const COVE_CATEGORIES_PIN_PALETTE = [
  'red' => [255, 0, 0],
  'blue' => [42, 129, 203],
  'green' => [42, 173, 39],
  'orange' => [203, 132, 39],
  'yellow' => [202, 196, 40],
  'violet' => [156, 43, 203],
  'grey' => [123, 123, 123],
  'black' => [61, 61, 61],
  'gold' => [201, 162, 43],
  'lime' => [90, 210, 29],
  'mint' => [29, 210, 120],
  'cyan' => [29, 192, 210],
  'indigo' => [67, 29, 210],
  'magenta' => [214, 25, 165],
  'pink' => [213, 93, 146],
  'navy' => [11, 66, 114],
  'teal' => [15, 133, 117],
  'brown' => [132, 75, 59],
  'maroon' => [101, 22, 19],
  'olive' => [65, 102, 29],
];

/**
 * Implements hook_leaflet_views_feature_alter().
 *
 * Replaces the default pin with the colored marker matching the place's
 * category, and tags the tooltip so the badge color matches.
 */
function cove_categories_leaflet_views_feature_alter(array &$feature, ResultRow $row, $rowPlugin): void {
  $node = $row->_entity ?? NULL;
  if (!$node instanceof NodeInterface
    || $node->bundle() !== 'place'
    || !$node->hasField('field_category')
    || $node->get('field_category')->isEmpty()) {
    return;
  }

  $category = $node->get('field_category')->entity;
  if (!$category instanceof CoveCategoryInterface) {
    return;
  }
  $palette_color = $category->getColor();
  if ($palette_color === NULL || !isset(COVE_CATEGORIES_PIN_PALETTE[$palette_color])) {
    return;
  }

  $base = '/modules/custom/cove_categories/images';
  $feature['icon']['iconUrl'] = $base . '/marker-icon-' . $palette_color . '.png';
  $feature['icon']['shadowUrl'] = $base . '/marker-shadow.png';
  $feature['icon']['iconSize'] = ['x' => '25', 'y' => '41'];
  $feature['icon']['iconAnchor'] = ['x' => '12', 'y' => '41'];
  $feature['icon']['shadowSize'] = ['x' => '41', 'y' => '41'];
  $feature['icon']['shadowAnchor'] = ['x' => '12', 'y' => '41'];
  $feature['icon']['popupAnchor'] = ['x' => '1', 'y' => '-34'];

  // Tag the tooltip className so CSS can match the badge color to the pin.
  if (!empty($feature['tooltip']['options'])) {
    $tooltip_options = json_decode($feature['tooltip']['options'], TRUE);
    if (is_array($tooltip_options)) {
      $existing = $tooltip_options['className'] ?? '';
      $tooltip_options['className'] = trim($existing . ' cove-color-' . $palette_color);
      $feature['tooltip']['options'] = json_encode($tooltip_options);
    }
  }
}

/**
 * Implements hook_ENTITY_TYPE_update() for cove_category.
 *
 * A category color change must refresh the maps, timelines and galleries that
 * render it. Those views carry the generic 'node_list' cache tag (not the
 * bundle-specific one), so that is the tag to invalidate.
 */
function cove_categories_cove_category_update(CoveCategoryInterface $category): void {
  \Drupal::service('cache_tags.invalidator')->invalidateTags(['node_list']);
}

/**
 * Allowed values callback for the cove_category color field.
 *
 * The color options are the keys of the fixed 20-color palette.
 */
function cove_categories_category_color_allowed_values(): array {
  $options = [];
  foreach (array_keys(COVE_CATEGORIES_PIN_PALETTE) as $key) {
    $options[$key] = ucfirst($key);
  }
  return $options;
}

/**
 * Maps a child bundle to the field holding its parent timeline / map / exhibit.
 */
function _cove_categories_child_parent_field(string $bundle): ?string {
  return [
    'chronology_entry' => 'field_parent_chronology',
    'place' => 'field_parent_map',
    'gallery_image' => 'field_featured_in_exhibit',
  ][$bundle] ?? NULL;
}

/**
 * Returns the origin course ids for a child node, via its parent(s).
 *
 * A child keeps the categories of the course where its parent was created
 * (field_origin_group), even when the parent is later added to other courses.
 */
function _cove_categories_origin_course_ids(NodeInterface $child): array {
  $parent_field = _cove_categories_child_parent_field($child->bundle());
  if ($parent_field === NULL || !$child->hasField($parent_field)) {
    return [];
  }

  $parent_ids = [];
  foreach ($child->get($parent_field)->referencedEntities() as $parent) {
    $parent_ids[] = (int) $parent->id();
  }

  return _cove_categories_courses_from_parent_ids($parent_ids);
}

/**
 * Resolves a set of parent node ids to their distinct origin course ids.
 */
function _cove_categories_courses_from_parent_ids(array $parent_ids): array {
  if (!$parent_ids) {
    return [];
  }

  $parents = \Drupal::entityTypeManager()->getStorage('node')->loadMultiple($parent_ids);
  $course_ids = [];
  foreach ($parents as $parent) {
    if ($parent->hasField('field_origin_group') && !$parent->get('field_origin_group')->isEmpty()) {
      $course_ids[] = (int) $parent->get('field_origin_group')->target_id;
    }
  }

  return array_values(array_unique($course_ids));
}

/**
 * Builds category options for a set of courses, grouped by course label.
 *
 * @return array
 *   An array keyed by course label, each value an array of
 *   [category id => category label]. Empty when no course is in scope.
 */
function _cove_categories_grouped_category_options(array $course_ids): array {
  if (!$course_ids) {
    return [];
  }

  $storage = \Drupal::entityTypeManager()->getStorage('cove_category');
  $ids = $storage->getQuery()
    ->accessCheck(TRUE)
    ->condition('group', $course_ids, 'IN')
    ->sort('label')
    ->execute();
  if (!$ids) {
    return [];
  }

  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $grouped = [];
  foreach ($storage->loadMultiple($ids) as $category) {
    /** @var \Drupal\cove_categories\Entity\CoveCategoryInterface $category */
    $course_id = $category->getGroupId();
    if ($course_id === NULL) {
      continue;
    }
    if (!isset($grouped[$course_id])) {
      $course = $node_storage->load($course_id);
      $grouped[$course_id] = [
        'label' => $course !== NULL ? (string) $course->label() : (string) $course_id,
        'options' => [],
      ];
    }
    $grouped[$course_id]['options'][$category->id()] = (string) $category->label();
  }

  $result = [];
  foreach ($grouped as $group) {
    $result[$group['label']] = $group['options'];
  }
  return $result;
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node forms.
 *
 * On child content (chronology_entry / place / gallery_image), scopes the
 * field_category dropdown to the parent's course(s) with an AJAX refresh.
 */
function cove_categories_form_node_form_alter(array &$form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof EntityFormInterface) {
    return;
  }
  $node = $form_object->getEntity();
  if (!$node instanceof NodeInterface) {
    return;
  }

  $parent_field = _cove_categories_child_parent_field($node->bundle());
  if ($parent_field !== NULL
    && isset($form['field_category']['widget'], $form[$parent_field]['widget'])) {
    // Recompute the category options on every build from the current parent.
    $wrapper_id = 'cove-category-options-wrapper';
    $form['field_category']['#prefix'] = '<div id="' . $wrapper_id . '">';
    $form['field_category']['#suffix'] = '</div>';
    $form['field_category']['#cove_parent_field'] = $parent_field;
    $form['field_category']['#after_build'][] = '_cove_categories_category_after_build';

    // Refresh the category dropdown when the parent selection changes.
    $form[$parent_field]['widget']['#ajax'] = [
      'callback' => '_cove_categories_category_ajax',
      'wrapper' => $wrapper_id,
      'event' => 'change',
    ];
    $form[$parent_field]['widget']['#limit_validation_errors'] = [[$parent_field]];
  }
}

/**
 * After-build callback: narrows field_category options to the parent course(s).
 */
function _cove_categories_category_after_build(array $element, FormStateInterface $form_state): array {
  $parent_field = $element['#cove_parent_field'] ?? NULL;
  if ($parent_field === NULL || !isset($element['widget']['#options'])) {
    return $element;
  }

  $course_ids = _cove_categories_course_ids_from_form_state($form_state, $parent_field);
  $grouped = _cove_categories_grouped_category_options($course_ids);

  // A single course in scope renders as a flat list, no optgroup.
  if (count($grouped) === 1) {
    $grouped = reset($grouped);
  }

  // Preserve the existing empty option for this non-required field.
  $options = [];
  if (isset($element['widget']['#options']['_none'])) {
    $options['_none'] = $element['widget']['#options']['_none'];
  }
  $element['widget']['#options'] = $options + $grouped;

  return $element;
}

/**
 * AJAX callback: returns the refreshed field_category element.
 */
function _cove_categories_category_ajax(array $form, FormStateInterface $form_state): array {
  return $form['field_category'];
}

/**
 * Resolves the course ids in scope from the current form state.
 *
 * Uses the parent selected in the form when present (AJAX rebuild), and falls
 * back to the saved parent of the node being edited on the initial build.
 */
function _cove_categories_course_ids_from_form_state(FormStateInterface $form_state, string $parent_field): array {
  $value = $form_state->getValue($parent_field);
  $parent_ids = [];
  if (is_array($value)) {
    foreach ($value as $item) {
      if (is_array($item) && isset($item['target_id']) && is_numeric($item['target_id'])) {
        $parent_ids[] = (int) $item['target_id'];
      }
    }
  }

  if ($parent_ids) {
    return _cove_categories_courses_from_parent_ids($parent_ids);
  }

  $node = $form_state->getFormObject()->getEntity();
  return $node instanceof NodeInterface ? _cove_categories_origin_course_ids($node) : [];
}
